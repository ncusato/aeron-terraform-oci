# Stack-generated config for aeron-io/benchmarks wrappers (source before running wrapper-echo-unified.sh).
# Paths and node IPs are set from Terraform/Ansible.

# -------- Global --------
RUNS="${RUNS:-5}"
ITERATIONS="${ITERATIONS:-30}"
WARMUP_ITERATIONS="${WARMUP_ITERATIONS:-10}"
MESSAGE_LENGTH="${MESSAGE_LENGTH:-288}"
MESSAGE_RATE="${MESSAGE_RATE:-101K}"
WARMUP_MESSAGE_RATE="${WARMUP_MESSAGE_RATE:-25K}"
MTU_VALUE="${MTU_VALUE:-8K}"

# Java 17+ required for benchmarks repo (--add-opens for Agrona)
JVM_OPTS="${JVM_OPTS:---add-opens java.base/jdk.internal.misc=ALL-UNNAMED --add-opens java.base/sun.nio.ch=ALL-UNNAMED}"

# -------- Paths (stack uses /opt/aeron) --------
export SSH_KEY_FILE="{{ aeron_dir }}/.ssh/deploy_key"
export CLIENT_BENCHMARKS_PATH="{{ benchmarks_dist_path }}"
export SERVER_BENCHMARKS_PATH="{{ benchmarks_dist_path }}"
export CLIENT_JAVA_HOME="/usr/lib/jvm/java-{{ java_version }}-openjdk-amd64"
export SERVER_JAVA_HOME="/usr/lib/jvm/java-{{ java_version }}-openjdk-amd64"

# -------- Echo (2-node) client/server IPs from Terraform --------
export SSH_USER="{{ ssh_username | default('ubuntu') }}"
export SSH_CLIENT_NODE="{{ client_node_ip | default('') }}"
export SSH_SERVER_NODE="{{ receiver_node_ip | default('') }}"

# -------- Cluster benchmark topology --------
# client   -> benchmark-1
# node0    -> benchmark-2
# backup   -> failover node (only when enabled/provisioned)
export CLUSTER_SSH_CLIENT_NODE="{{ client_node_ip | default('') }}"
export CLUSTER_SSH_CLUSTER_NODE0="{{ receiver_node_ip | default('') }}"
export CLUSTER_SSH_BACKUP_NODE0="{{ failover_node_ip | default('') }}"
export CLUSTER_BACKUP_NODES="${CLUSTER_BACKUP_NODES:-{% if (failover_node_ip | default('')) != '' %}1{% else %}0{% endif %}}"

# Ensure cluster wrapper uses /opt/aeron deployment paths
export CLUSTER_CLIENT_BENCHMARKS_PATH="{{ benchmarks_dist_path }}"
export CLUSTER_NODE0_BENCHMARKS_PATH="{{ benchmarks_dist_path }}"
export CLUSTER_AERON_SSH_TASKSET_CPUS="${CLUSTER_AERON_SSH_TASKSET_CPUS:-0-15}"

# Aeron latency tuning
export AERON_SOCKET_SO_SNDBUF="${AERON_SOCKET_SO_SNDBUF:-2m}"
export AERON_SOCKET_SO_RCVBUF="${AERON_SOCKET_SO_RCVBUF:-2m}"
export AERON_NETWORK_PUBLICATION_MAX_MESSAGES_PER_SEND="${AERON_NETWORK_PUBLICATION_MAX_MESSAGES_PER_SEND:-1}"
export AERON_RECEIVER_IO_VECTOR_CAPACITY="${AERON_RECEIVER_IO_VECTOR_CAPACITY:-1}"
export AERON_SENDER_IO_VECTOR_CAPACITY="${AERON_SENDER_IO_VECTOR_CAPACITY:-1}"
