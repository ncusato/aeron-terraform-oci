# Aeron Benchmark Configuration
# Generated by Terraform/Ansible deployment (aligned with quickstart profile)

aeron_dir: "{{ aeron_dir }}"
java_version: "{{ java_version }}"
hyperthreading: {{ hyperthreading }}

# Reference profile for reproducible baselines
message_length: {{ message_length }}
message_rate: "{{ message_rate }}"
socket_buf: {{ socket_buf }}

# Latency-first Aeron tuning
aeron_max_messages_per_send: {{ aeron_max_messages_per_send }}
aeron_receiver_io_vector_capacity: {{ aeron_receiver_io_vector_capacity }}
aeron_sender_io_vector_capacity: {{ aeron_sender_io_vector_capacity }}
aeron_socket_so_sndbuf: "{{ aeron_socket_so_sndbuf | default('2m') }}"
aeron_socket_so_rcvbuf: "{{ aeron_socket_so_rcvbuf | default('2m') }}"

# CPU isolation (when apply_cpu_isolation_grub is enabled)
housekeeping_cpus: "{{ housekeeping_cpus }}"
isolated_cpus: "{{ isolated_cpus }}"
irq_affinity: "{{ irq_affinity }}"

# Benchmark sweep parameters
message_sizes:
{% for size in benchmark_message_sizes %}
  - {{ size }}
{% endfor %}

burst_lengths:
{% for burst in benchmark_burst_lengths %}
  - {{ burst }}
{% endfor %}

iterations: {{ benchmark_iterations }}

# Java options
java_opts: "{{ aeron_java_opts }}"
